# ============================================================
# Saphire — Environment variables
# ============================================================
# Copy this file to .env and adjust the values.
# Variables defined here override saphire.toml.
# ============================================================

# ── Main database ──
SAPHIRE_DB_PASSWORD=saphire_soul

# ── Logs database ──
SAPHIRE_LOGS_DB_PASSWORD=saphire_logs

# ── API key to protect the web interface (optional) ──
# Generate a random key: openssl rand -hex 32
# SAPHIRE_API_KEY=votre-cle-secrete-ici
