# ============================================================
# Saphire — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et adapter les valeurs.
# Les variables definies ici surchargent saphire.toml.
# ============================================================

# ── Base de donnees principale ──
SAPHIRE_DB_PASSWORD=saphire_soul

# ── Base de donnees de logs ──
SAPHIRE_LOGS_DB_PASSWORD=saphire_logs

# ── Cle API pour proteger l'interface web (optionnelle) ──
# Generer une cle aleatoire : openssl rand -hex 32
# SAPHIRE_API_KEY=votre-cle-secrete-ici
