# Timer systemd — execute le watchdog GPU toutes les minutes.
#
# Installation :
#   sudo cp scripts/gpu-watchdog.service scripts/gpu-watchdog.timer /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now gpu-watchdog.timer

[Unit]
Description=Saphire GPU Watchdog Timer

[Timer]
OnBootSec=60
OnUnitActiveSec=60
AccuracySec=5

[Install]
WantedBy=timers.target
